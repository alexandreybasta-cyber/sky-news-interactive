generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("EMPLOYEE") // MANAGER | EMPLOYEE
  createdAt DateTime @default(now())

  shifts         Shift[]        @relation("UserShifts")
  createdShifts  Shift[]        @relation("CreatedShifts")
  stories        Story[]        @relation("AssignedStories")
  createdStories Story[]        @relation("CreatedStories")
  swapRequests   SwapRequest[]  @relation("RequesterSwaps")
  availability   Availability[]
}

model Shift {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime
  type       String   // MORNING | AFTERNOON | NIGHT | DAY_OFF
  weekNumber Int
  createdBy  String
  createdAt  DateTime @default(now())

  user    User @relation("UserShifts", fields: [userId], references: [id])
  creator User @relation("CreatedShifts", fields: [createdBy], references: [id])

  targetSwaps  SwapRequest[] @relation("TargetShift")
  offeredSwaps SwapRequest[] @relation("OfferedShift")
}

model Story {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("PLANNED") // PLANNED | IN_PROGRESS | AIRED
  assignedTo  String?
  deadline    DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignee User? @relation("AssignedStories", fields: [assignedTo], references: [id])
  creator  User  @relation("CreatedStories", fields: [createdBy], references: [id])
}

model SwapRequest {
  id             String   @id @default(cuid())
  requesterId    String
  targetShiftId  String
  offeredShiftId String?
  status         String   @default("PENDING") // PENDING | APPROVED | REJECTED
  respondedBy    String?
  createdAt      DateTime @default(now())

  requester    User   @relation("RequesterSwaps", fields: [requesterId], references: [id])
  targetShift  Shift  @relation("TargetShift", fields: [targetShiftId], references: [id])
  offeredShift Shift? @relation("OfferedShift", fields: [offeredShiftId], references: [id])
}

model Availability {
  id               String   @id @default(cuid())
  userId           String
  weekNumber       Int
  year             Int
  unavailableDates String   // JSON array of date strings
  preferredShift   String?  // MORNING | AFTERNOON | NIGHT
  notes            String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

